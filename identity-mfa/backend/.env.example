# Copy to .env and adjust. Never commit real secrets.
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_generate_random_32plus_chars

# PostgreSQL (matches docker-compose defaults for local dev only)
DATABASE_URL="postgresql://user:pass@127.0.0.1:5434/identity_mfa?serverVersion=14&charset=utf8"

# HS256 signing for short-lived MFA step-up tokens (rotate for non-local)
JWT_SECRET=dev_only_replace_me

# Redis (optional; rate limits / future token denylist)
REDIS_URL=redis://127.0.0.1:6379
